{
  "name": "poc-stake",
  "version": "1.0.0",
  "private": true,
  "description": "DedlyFi Staking Platform — unified monorepo",
  "scripts": {
    "start": "concurrently -n backend,frontend -c blue,magenta \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && nodemon src/index.ts",
    "start:frontend": "concurrently -n next,ready -c magenta,gray \"cd frontend && next dev\" \"wait-on http://localhost:3000 && node frontend/scripts/on-ready.js\"",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && tsc",
    "build:frontend": "cd frontend && next build",
    "lint": "cd frontend && eslint",
    "contracts:compile": "cd contracts && hardhat compile",
    "contracts:test": "cd contracts && hardhat test",
    "contracts:deploy": "cd contracts && hardhat run scripts/deploy.ts --network sepolia",
    "contracts:deploy:local": "cd contracts && hardhat run scripts/deploy.ts --network hardhat",
    "contracts:setup:sepolia": "cd contracts && hardhat run scripts/setup_sepolia.ts --network sepolia"
  },
  "dependencies": {
    "@bull-board/api": "^6.14.2",
    "@bull-board/express": "^6.14.2",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.16.1",
    "bullmq": "^5.65.1",
    "canvas-confetti": "^1.9.4",
    "chalk": "^4.1.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "express": "^5.2.0",
    "framer-motion": "^12.23.25",
    "graphql": "^16.12.0",
    "graphql-request": "^7.3.5",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.555.0",
    "mongoose": "^9.1.6",
    "next": "^14.2.35",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "sonner": "^2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.41.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "hardhat": "^2.22.13",
    "nodemon": "^3.1.11",
    "open": "^11.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "uuid": "^11.1.0",
    "ws": "^8.21.0"
  }
}
